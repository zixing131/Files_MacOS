														<MenuFlyoutItem x:Uid="ContextCutItem" Click="ContextAction_Click" Tag="Cut" />
														<MenuFlyoutItem x:Uid="ContextCopyItem" Click="ContextAction_Click" Tag="Copy" />
														<MenuFlyoutItem x:Uid="ContextDuplicateItem" Click="ContextAction_Click" Tag="Duplicate" />
														<MenuFlyoutItem x:Uid="ContextCreateSymbolicLinkItem" Click="ContextAction_Click" Tag="CreateSymbolicLink" />
														<MenuFlyoutItem x:Uid="ContextCopyPathItem" Click="ContextAction_Click" Tag="CopyPath" />
														<MenuFlyoutItem x:Uid="ContextRenameItem" Click="ContextAction_Click" Tag="Rename" />
														<MenuFlyoutItem x:Uid="ContextShareItem" Click="ContextAction_Click" Tag="Share" />
														<MenuFlyoutSeparator />
														<MenuFlyoutItem x:Uid="ContextDeleteItem" Click="ContextAction_Click" Tag="Delete" />
														<MenuFlyoutItem x:Uid="ContextPermanentDeleteItem" Click="ContextAction_Click" Tag="PermanentDelete" />
														<MenuFlyoutItem x:Uid="ContextPropertiesItem" Click="ContextAction_Click" Tag="Properties" />
														<MenuFlyoutSeparator />
														<MenuFlyoutItem x:Uid="ContextCompressItem" Click="ContextAction_Click" Tag="Compress" />
														<MenuFlyoutItem x:Uid="ContextExtractItem" Click="ContextAction_Click" Tag="Extract" />
														<MenuFlyoutItem x:Uid="ContextFavoriteItem" Click="ContextAction_Click" Tag="Favorite" />
													</MenuFlyout>
												</Grid.ContextFlyout>
												<Grid Grid.Column="0" Width="24" Height="24">
													<PathIcon Width="20" Height="20" Data="{Binding IsDirectory, Converter={StaticResource FileSystemItemToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.72" />
													<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
												</Grid>
												<StackPanel Grid.Column="1" VerticalAlignment="Center">
													<TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
													<TextBlock
														FontSize="11"
														Foreground="{ThemeResource TextFillColorSecondaryBrush}"
														Text="{Binding SearchLocation}"
														TextTrimming="CharacterEllipsis"
														Visibility="{Binding IsSearchResult, Converter={StaticResource BooleanToVisibilityConverter}}" />
												</StackPanel>
												<TextBlock Grid.Column="2" Text="{Binding ModifiedText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
												<TextBlock Grid.Column="3" Text="{Binding SizeText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
											</Grid>
										</DataTemplate>
									</ListView.ItemTemplate>
								</ListView>
							</Grid>

							<StackPanel
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="8"
								Visibility="{Binding ActiveTab.SecondaryBrowser.IsEmptyFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
								<PathIcon x:Name="SecondaryEmptyFolderIcon" Width="64" Height="64" Data="M2,12 H25 L31,18 H62 V54 H2 Z M7,22 V49 H57 V22 Z" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.32" />
								<TextBlock x:Uid="EmptyFolderHeading" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
								<TextBlock x:Uid="EmptyFolderDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" />
							</StackPanel>
							<StackPanel
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="8"
								Visibility="{Binding ActiveTab.SecondaryBrowser.HasNoSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
								<PathIcon x:Name="SecondaryNoResultsIcon" Width="56" Height="56" Data="M24,4 A20,20 0 1 0 24,44 A20,20 0 0 0 24,4 Z M24,10 A14,14 0 1 1 24,38 A14,14 0 0 1 24,10 Z M38,39 L44,34 L56,47 L51,52 Z M18,18 H30 V22 H18 Z M18,27 H27 V31 H18 Z" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.32" />
								<TextBlock x:Uid="NoSearchResultsHeading" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
								<TextBlock x:Uid="NoSearchResultsDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" />
							</StackPanel>

							<ProgressRing
								Width="28"
								Height="28"
								HorizontalAlignment="Center"
								IsActive="{Binding ActiveTab.SecondaryBrowser.IsLoading}"
								VerticalAlignment="Center" />
						</Grid>
					</Border>
				</Grid>

				<Border
					x:Name="PreviewPaneBorder"
					Grid.Row="1"
					Width="312"
					Margin="8,0,0,0"
					HorizontalAlignment="Right"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="1"
					CornerRadius="8"
					Visibility="Collapsed">
					<Grid Padding="16" RowDefinitions="Auto,*,Auto">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock x:Uid="PreviewPaneHeading" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
							<Button
								x:Name="ClosePreviewPaneButton"
								Grid.Column="1"
								Click="ClosePreviewPaneButton_Click"
								Style="{StaticResource NavigationButtonStyle}">
								<PathIcon Width="11" Height="11" Data="M3,2 L10,9 L17,2 L18,3 L11,10 L18,17 L17,18 L10,11 L3,18 L2,17 L9,10 L2,3 Z" />
							</Button>
						</Grid>
						<ScrollViewer Grid.Row="1" Margin="0,16,0,8" VerticalScrollBarVisibility="Auto">
							<Grid>
								<TextBlock
									x:Name="PreviewSelectionSummary"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									TextAlignment="Center"
									TextWrapping="Wrap" />
								<StackPanel x:Name="PreviewPaneContent" Spacing="10" Visibility="Collapsed">
									<Grid Width="160" Height="160" HorizontalAlignment="Center">
										<PathIcon Width="88" Height="88" Data="{Binding IsDirectory, Converter={StaticResource FileSystemItemToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.58" />
										<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
									</Grid>
									<TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
									<TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Path}" TextAlignment="Center" TextWrapping="Wrap" />
									<Border Height="1" Margin="0,4" Background="{ThemeResource FilesCardBorderBrush}" />
									<Grid ColumnDefinitions="110,*">
										<TextBlock x:Uid="PreviewModifiedLabel" />
										<TextBlock Grid.Column="1" Text="{Binding ModifiedText}" TextWrapping="Wrap" />
									</Grid>
									<Grid ColumnDefinitions="110,*">
										<TextBlock x:Uid="PreviewSizeLabel" />
										<TextBlock Grid.Column="1" Text="{Binding SizeText}" />
									</Grid>
								</StackPanel>
							</Grid>
						</ScrollViewer>
						<Button
							x:Name="PreviewPaneQuickLookButton"
							x:Uid="PreviewPaneQuickLookButton"
							Grid.Row="2"
							Click="PreviewPaneQuickLookButton_Click"
							HorizontalAlignment="Stretch"
							IsEnabled="False" />
					</Grid>
				</Border>

				<!--  Status bar  -->
				<Grid Grid.Row="2" Margin="12,0" ColumnDefinitions="*,180,Auto,Auto" ColumnSpacing="8">
					<TextBlock
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="{Binding ActiveBrowser.StatusText}"
					TextTrimming="CharacterEllipsis"
					VerticalAlignment="Center" />
					<ProgressBar
						x:Name="FileOperationProgressBar"
						Grid.Column="1"
						Maximum="100"
						Visibility="Collapsed"
						VerticalAlignment="Center"
						Value="0" />
					<Button
						x:Name="CancelOperationButton"
						x:Uid="CancelOperationButton"
						Grid.Column="2"
						Click="CancelOperationButton_Click"
						Style="{StaticResource ToolbarButtonStyle}"
						Visibility="Collapsed" />
					<Border Grid.Column="3" Padding="2" VerticalAlignment="Center" Background="{ThemeResource FilesSubtleBrush}" CornerRadius="5">
						<StackPanel Orientation="Horizontal" Spacing="1">
							<Button x:Name="GridViewStatusButton" Click="GridViewStatusButton_Click" Style="{StaticResource StatusViewButtonStyle}">
								<PathIcon Width="14" Height="14" Data="M2,2 H8 V8 H2 Z M12,2 H18 V8 H12 Z M2,12 H8 V18 H2 Z M12,12 H18 V18 H12 Z" />
							</Button>
							<Button x:Name="DetailsViewStatusButton" Click="DetailsViewStatusButton_Click" Style="{StaticResource StatusViewButtonStyle}">
								<PathIcon Width="14" Height="14" Data="M2,3 H5 V6 H2 Z M7,3 H18 V6 H7 Z M2,8 H5 V11 H2 Z M7,8 H18 V11 H7 Z M2,13 H5 V16 H2 Z M7,13 H18 V16 H7 Z" />
							</Button>
						</StackPanel>
					</Border>
				</Grid>
			</Grid>
		</Grid>
	</Grid>

</Page>
