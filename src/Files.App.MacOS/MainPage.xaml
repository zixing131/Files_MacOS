<Page
	x:Class="Files.App.MacOS.MainPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="using:Files.App.MacOS.Converters"
	xmlns:controls="using:Files.App.MacOS.Controls"
	xmlns:viewmodels="using:Files.App.MacOS.ViewModels"
	Background="{ThemeResource FilesBackgroundBrush}">

	<Page.Resources>
		<converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<converters:FileSystemItemToIconConverter x:Key="FileSystemItemToIconConverter" />
		<converters:SidebarGlyphToIconConverter x:Key="SidebarGlyphToIconConverter" />
	</Page.Resources>
	<Page.KeyboardAccelerators>
		<KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Control" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Control" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F" Modifiers="Control" Invoked="SearchAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Control" Invoked="AddressAccelerator_Invoked" />
		<KeyboardAccelerator Key="A" Modifiers="Control" Invoked="SelectAllAccelerator_Invoked" />
		<KeyboardAccelerator Key="I" Modifiers="Control,Shift" Invoked="InvertSelectionAccelerator_Invoked" />
		<KeyboardAccelerator Key="C" Modifiers="Control,Shift" Invoked="CopyPathAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Control,Shift" Invoked="RedoAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Control,Shift" Invoked="SplitViewAccelerator_Invoked" />
		<KeyboardAccelerator Key="Delete" Modifiers="Shift" Invoked="PermanentDeleteAccelerator_Invoked" />
		<KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OpenInNewTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="T" Modifiers="Control,Shift" Invoked="ReopenClosedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="K" Modifiers="Control,Shift" Invoked="DuplicateTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="NextTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="PreviousTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number1" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number2" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number3" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number4" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number5" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number6" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number7" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number8" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number9" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="F6" Invoked="CycleFocusAccelerator_Invoked" />
		<KeyboardAccelerator Key="F6" Modifiers="Shift" Invoked="CycleFocusAccelerator_Invoked" />
		<!--  Uno maps the macOS Command key to the WinUI Windows modifier.  -->
		<KeyboardAccelerator Key="C" Modifiers="Windows" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Windows" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Windows" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F" Modifiers="Windows" Invoked="SearchAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Windows" Invoked="AddressAccelerator_Invoked" />
		<KeyboardAccelerator Key="A" Modifiers="Windows" Invoked="SelectAllAccelerator_Invoked" />
		<KeyboardAccelerator Key="I" Modifiers="Windows,Shift" Invoked="InvertSelectionAccelerator_Invoked" />
		<KeyboardAccelerator Key="C" Modifiers="Windows,Shift" Invoked="CopyPathAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows" Invoked="UndoAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows,Shift" Invoked="RedoAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows,Shift" Invoked="SplitViewAccelerator_Invoked" />
		<KeyboardAccelerator Key="Enter" Modifiers="Windows" Invoked="OpenInNewTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows" Invoked="DuplicateAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Windows,Menu" Invoked="CreateSymbolicLinkAccelerator_Invoked" />
		<KeyboardAccelerator Key="N" Modifiers="Windows" Invoked="NewWindowAccelerator_Invoked" />
		<KeyboardAccelerator Key="W" Modifiers="Windows,Shift" Invoked="CloseWindowAccelerator_Invoked" />
		<KeyboardAccelerator Key="T" Modifiers="Windows,Shift" Invoked="ReopenClosedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="K" Modifiers="Windows,Shift" Invoked="DuplicateTabAccelerator_Invoked" />
	</Page.KeyboardAccelerators>

	<Grid RowDefinitions="44,48,*">
		<!--  Tab strip  -->
		<Border x:Name="TitleBarBackground" Grid.Row="0" Background="{ThemeResource FilesBackgroundBrush}" />
		<TabView
			x:Name="Tabs"
			Grid.Row="0"
			Margin="76,4,4,0"
			AddTabButtonClick="Tabs_AddTabButtonClick"
			AllowDropTabs="True"
			CanDragTabs="True"
			CanReorderTabs="True"
			IsAddTabButtonVisible="False"
			SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
			SelectionChanged="Tabs_SelectionChanged"
			PointerWheelChanged="Tabs_PointerWheelChanged"
			TabCloseRequested="Tabs_TabCloseRequested"
			TabDragCompleted="Tabs_TabDragCompleted"
			TabDroppedOutside="Tabs_TabDroppedOutside"
			TabItemsSource="{Binding Tabs}"
			TabWidthMode="Equal">
			<TabView.TabItemTemplate>
				<DataTemplate x:DataType="viewmodels:BrowserTabViewModel">
					<TabViewItem
						AutomationProperties.Name="{Binding Header}"
						MinWidth="132"
						MaxWidth="260"
						CornerRadius="7,7,0,0"
						IsClosable="False"
						PointerEntered="TabItem_PointerEntered"
						PointerExited="TabItem_PointerExited"
						Tag="{Binding}">
						<TabViewItem.ContextFlyout>
							<MenuFlyout Opening="TabContextFlyout_Opening">
								<MenuFlyoutItem x:Uid="NewTabMenuItem" Click="NewTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘T" />
								<MenuFlyoutItem x:Uid="DuplicateTabMenuItem" Click="DuplicateTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘⇧K" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="MoveTabToNewWindowMenuItem" Click="MoveTabToNewWindowMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem x:Uid="CloseTabMenuItem" Click="CloseTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘W" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseTabsToLeftMenuItem" Click="CloseTabsToLeftMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseTabsToRightMenuItem" Click="CloseTabsToRightMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseOtherTabsMenuItem" Click="CloseOtherTabsMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem x:Uid="ReopenClosedTabMenuItem" Click="ReopenClosedTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘⇧T" />
							</MenuFlyout>
						</TabViewItem.ContextFlyout>
						<TabViewItem.Header>
							<StackPanel Orientation="Horizontal" Spacing="7">
								<PathIcon Width="16" Height="16" Data="M2,4 H8 L10,6 H18 V17 H2 Z M4,8 V15 H16 V8 Z" />
								<TextBlock MaxWidth="180" Text="{x:Bind Header, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
								<Grid Width="22" Height="22">
									<Button Width="22" Height="22" Padding="0" Click="TabHeaderCloseButton_Click" Loaded="TabHeaderCloseButton_Loaded" Style="{StaticResource NavigationButtonStyle}" Tag="{Binding}" Visibility="{Binding ShowCloseButton, Converter={StaticResource BooleanToVisibilityConverter}}">
										<PathIcon Width="10" Height="10" Data="M3,2 L10,9 L17,2 L18,3 L11,10 L18,17 L17,18 L10,11 L3,18 L2,17 L9,10 L2,3 Z" />
									</Button>
								</Grid>
							</StackPanel>
						</TabViewItem.Header>
					</TabViewItem>
				</DataTemplate>
			</TabView.TabItemTemplate>
			<TabView.TabStripFooter>
				<Button x:Name="NewTabButton" Width="32" Click="NewTabButton_Click" Style="{StaticResource NavigationButtonStyle}">
					<PathIcon Width="14" Height="14" Data="M9,2 H11 V9 H18 V11 H11 V18 H9 V11 H2 V9 H9 Z" />
				</Button>
			</TabView.TabStripFooter>
		</TabView>

		<!--  Address toolbar  -->
		<Grid
			x:Name="AddressToolbarGrid"
			Grid.Row="1"
			Padding="8,6"
			Background="{ThemeResource FilesToolbarBrush}"
			ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
			ColumnSpacing="4">
			<Button
				x:Name="ToggleSidebarButton"
				Grid.Column="0"
				Click="ToggleSidebarButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="16" Height="16" Data="M2,3 H18 V17 H2 Z M4,5 V15 H8 V5 Z M10,6 H16 V8 H10 Z M10,10 H16 V12 H10 Z" />
			</Button>
			<Button
				x:Name="BackButton"
				Grid.Column="1"
				Click="BackButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoBack}"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="16" Height="16" Data="M8,2 L1,10 L8,18 L10,16 L6,12 H18 V8 H6 L10,4 Z" />
			</Button>
			<Button
				x:Name="ForwardButton"
				Grid.Column="2"
				Click="ForwardButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoForward}"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="16" Height="16" Data="M12,2 L19,10 L12,18 L10,16 L14,12 H2 V8 H14 L10,4 Z" />
			</Button>
			<Button
				x:Name="UpButton"
				Grid.Column="3"
				Click="UpButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="16" Height="16" Data="M10,2 L18,10 L16,12 L12,8 V18 H8 V8 L4,12 L2,10 Z" />
			</Button>
			<Button
				x:Name="RefreshButton"
				Grid.Column="4"
				Click="RefreshButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="16" Height="16" Data="M10,2 A8,8 0 0 1 17,6 V2 H19 V9 H12 V7 H15 A6,6 0 1 0 16,13 L18,14 A8,8 0 1 1 10,2 Z" />
			</Button>

			<Border
				x:Name="AddressBarBorder"
				Grid.Column="5"
				Margin="4,0"
				Background="{ThemeResource FilesCardBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="1"
				CornerRadius="6"
				PointerPressed="AddressBarBorder_PointerPressed">
				<Grid>
					<ScrollViewer
						x:Name="BreadcrumbScrollViewer"
						HorizontalScrollBarVisibility="Hidden"
						HorizontalScrollMode="Enabled"
						VerticalScrollMode="Disabled">
						<StackPanel
							x:Name="BreadcrumbPanel"
							Margin="4,0"
							Orientation="Horizontal" />
					</ScrollViewer>
					<TextBox
						x:Name="AddressBox"
						x:Uid="AddressBox"
						Background="Transparent"
						BorderThickness="0"
						KeyDown="AddressBox_KeyDown"
						LostFocus="AddressBox_LostFocus"
						Visibility="Collapsed" />
				</Grid>
			</Border>

			<Grid Grid.Column="6" Width="260">
				<TextBox
					x:Name="SearchBox"
					x:Uid="SearchBox"
					Padding="12,0,36,0"
					Text="{Binding ActiveBrowser.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
					TextChanged="SearchBox_TextChanged" />
				<Button
					x:Name="SearchOptionsButton"
					Width="32"
					HorizontalAlignment="Right"
					Background="Transparent"
					BorderThickness="0"
					Click="SearchOptionsButton_Click">
					<PathIcon Width="12" Height="12" Data="M2,4 L7,9 L12,4 L14,6 L7,13 L0,6 Z" />
				</Button>
			</Grid>
		</Grid>

		<!--  Sidebar and file area  -->
		<Grid x:Name="WorkspaceGrid" Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="SidebarColumn" Width="228" />
				<ColumnDefinition x:Name="SidebarDividerColumn" Width="6" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Border
				x:Name="SidebarBorder"
				Grid.Column="0"
				Background="{ThemeResource FilesSidebarBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="0,1,1,0">
				<Grid Padding="8" RowDefinitions="*,Auto">
					<ListView
						x:Name="SidebarList"
						HorizontalContentAlignment="Stretch"
						ItemContainerStyle="{StaticResource SidebarListItemStyle}"
						ItemsSource="{Binding Locations}"
						SelectionChanged="SidebarList_SelectionChanged"
						SelectionMode="Single">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid AutomationProperties.Name="{Binding Name}">
								<Grid
									MinHeight="32"
									Padding="8,6,8,2"
									ColumnDefinitions="16,*"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
									<PathIcon Width="11" Height="11" Data="{Binding DisplayGlyph, Converter={StaticResource SidebarGlyphToIconConverter}}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Name}" VerticalAlignment="Center" />
								</Grid>
								<Grid
									MinHeight="36"
									Padding="8,0"
									ColumnDefinitions="24,*"
									ColumnSpacing="8"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
									<PathIcon Width="18" Height="18" Data="{Binding DisplayGlyph, Converter={StaticResource SidebarGlyphToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
								</Grid>
							</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>

					<StackPanel Grid.Row="1" Spacing="2">
						<Border Height="1" Margin="4,2" Background="{ThemeResource FilesCardBorderBrush}" />
						<Button
							x:Name="OpenFolderButton"
							Click="OpenFolderButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="OpenFolderButton" IconData="M2,4 H8 L10,6 H18 V17 H2 Z M4,8 V15 H16 V8 Z M9,9 H11 V11 H13 V13 H11 V15 H9 V13 H7 V11 H9 Z" />
						</Button>
						<Button
							x:Name="ConnectServerButton"
							Click="ConnectServerButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="ConnectServerButton" IconData="M3,3 H17 V10 H3 Z M5,5 V8 H15 V5 Z M4,12 H9 V18 H4 Z M11,12 H16 V18 H11 Z M6,14 V16 H7 V14 Z M13,14 V16 H14 V14 Z" />
						</Button>
						<Button
							x:Name="ClearRecentButton"
							Click="ClearRecentButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}"
							Visibility="{Binding HasRecentLocations, Converter={StaticResource BooleanToVisibilityConverter}}">
							<controls:CommandLabel x:Uid="ClearRecentButton" IconData="M10,2 A8,8 0 0 1 17,6 V2 H19 V9 H12 V7 H15 A6,6 0 1 0 16,13 L18,14 A8,8 0 1 1 10,2 Z M6,8 L8,6 L10,8 L12,6 L14,8 L12,10 L14,12 L12,14 L10,12 L8,14 L6,12 L8,10 Z" />
						</Button>
						<Button
							x:Name="SettingsButton"
							Click="SettingsButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="SettingsButton" IconData="M8,2 H12 L13,5 L16,4 L18,8 L15,10 L18,12 L16,16 L13,15 L12,18 H8 L7,15 L4,16 L2,12 L5,10 L2,8 L4,4 L7,5 Z M10,7 A3,3 0 1 0 10,13 A3,3 0 0 0 10,7 Z" />
						</Button>
					</StackPanel>
				</Grid>
			</Border>
			<Button
				x:Name="SidebarDivider"
				Grid.Column="1"
				KeyDown="SidebarDivider_KeyDown"
				Style="{StaticResource DividerButtonStyle}">
				<Border Width="1" HorizontalAlignment="Center" Background="{ThemeResource FilesCardBorderBrush}" />
			</Button>

			<Grid Grid.Column="2" Padding="8,6,8,8" RowDefinitions="48,*,36">
				<!--  File command toolbar  -->
				<Border
					x:Name="CommandToolbarBorder"
					Grid.Row="0"
					Margin="0,0,0,6"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="1"
					CornerRadius="8"
					SizeChanged="CommandToolbarBorder_SizeChanged">
					<Grid Padding="8,4" ColumnDefinitions="*,Auto">
						<ScrollViewer HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Enabled">
							<StackPanel Orientation="Horizontal" Spacing="2">
								<Button x:Name="UndoButton" Click="UndoButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="UndoButton" IconData="M8,3 L2,9 L8,15 L8,11 C13,11 16,13 18,17 C18,9 14,5 8,5 Z" />
								</Button>
								<Button x:Name="RedoButton" Click="RedoButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="RedoButton" IconData="M12,3 L18,9 L12,15 L12,11 C7,11 4,13 2,17 C2,9 6,5 12,5 Z" />
								</Button>
								<Border x:Name="HistoryCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Name="NewCommandButton" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout>
											<MenuFlyoutItem x:Uid="NewFolderMenuItem" Click="NewButton_Click" />
											<MenuFlyoutItem x:Uid="NewTextFileMenuItem" Click="NewTextFileButton_Click" />
										</MenuFlyout>
									</Button.Flyout>
									<controls:CommandLabel x:Uid="NewButton" IconData="M9,3 H11 V9 H17 V11 H11 V17 H9 V11 H3 V9 H9 Z" />
								</Button>
								<Button x:Name="CutButton" Click="CutButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="CutButton" IconData="M5,2 A3,3 0 1 0 5,8 A3,3 0 0 0 7,7 L9,9 L7,11 A3,3 0 1 0 8,13 L10,11 L16,17 H19 L12,10 L19,3 H16 L10,9 L8,7 A3,3 0 0 0 5,2 Z M5,4 A1,1 0 1 1 5,6 A1,1 0 0 1 5,4 Z M5,12 A1,1 0 1 1 5,14 A1,1 0 0 1 5,12 Z" />
								</Button>
								<Button x:Name="CopyButton" Click="CopyButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="CopyButton" IconData="M3,3 H13 V6 H17 V17 H7 V14 H3 Z M5,5 V12 H7 V6 H11 V5 Z M9,8 V15 H15 V8 Z" />
								</Button>
								<Button x:Name="PasteButton" Click="PasteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="PasteButton" IconData="M7,2 H13 L14,4 H17 V18 H3 V4 H6 Z M8,4 V6 H12 V4 Z M5,6 V16 H15 V6 H14 V8 H6 V6 Z" />
								</Button>
								<Border x:Name="EditCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Name="RenameButton" Click="RenameButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="RenameButton" IconData="M13,2 L18,7 L7,18 H2 V13 Z M13,5 L5,13 V15 H7 L15,7 Z" />
								</Button>
								<Button x:Name="ShareButton" Click="ShareButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="ShareButton" IconData="M10,2 L16,8 H12 V12 C7,12 4,14 2,18 C2,10 6,7 12,7 V6 Z" />
								</Button>
								<Button x:Name="DeleteButton" Click="DeleteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="DeleteButton" IconData="M6,2 H14 L15,4 H18 V6 H2 V4 H5 Z M4,7 H16 L15,18 H5 Z M7,9 V16 H9 V9 Z M11,9 V16 H13 V9 Z" />
								</Button>
								<Border x:Name="SecondaryCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Name="RevealButton" Click="RevealButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="RevealButton" IconData="M2,4 H8 L10,6 H18 V17 H2 Z M4,8 V15 H16 V8 Z" />
								</Button>
								<Button x:Name="PropertiesButton" Click="PropertiesButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="PropertiesButton" IconData="M10,2 A8,8 0 1 0 10,18 A8,8 0 0 0 10,2 Z M9,6 H11 V8 H9 Z M9,9 H11 V15 H9 Z" />
								</Button>
								<Button x:Name="SelectionButton" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout>
											<MenuFlyoutItem x:Uid="SelectAllMenuItem" Click="SelectAllMenuItem_Click" />
											<MenuFlyoutItem x:Uid="InvertSelectionMenuItem" Click="InvertSelectionMenuItem_Click" />
											<MenuFlyoutSeparator />
											<MenuFlyoutItem x:Name="CopyPathMenuItem" x:Uid="CopyPathMenuItem" Click="CopyPathMenuItem_Click" IsEnabled="False" />
										</MenuFlyout>
									</Button.Flyout>
									<controls:CommandLabel x:Uid="SelectionButton" IconData="M3,3 H8 V5 H5 V8 H3 Z M12,3 H17 V8 H15 V5 H12 Z M3,12 H5 V15 H8 V17 H3 Z M10,14 L12,16 L17,10 L18,12 L12,19 L9,16 Z" />
								</Button>
								<Button x:Name="ArchiveButton" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout Opening="ArchiveFlyout_Opening">
											<MenuFlyoutItem x:Uid="CompressArchiveMenuItem" Click="CompressArchiveMenuItem_Click" />
											<MenuFlyoutItem x:Name="ExtractArchiveMenuItem" x:Uid="ExtractArchiveMenuItem" Click="ExtractArchiveMenuItem_Click" />
										</MenuFlyout>
									</Button.Flyout>
									<controls:CommandLabel x:Uid="ArchiveButton" IconData="M2,3 H18 V7 H17 V18 H3 V7 H2 Z M4,5 H16 V6 H4 Z M8,9 H12 V11 H8 Z" />
								</Button>
								<Button x:Name="FavoriteButton" Click="FavoriteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<controls:CommandLabel x:Uid="FavoriteButton" IconData="M10,2 L12.4,7 L18,7.6 L14,11.5 L15,17 L10,14.3 L5,17 L6,11.5 L2,7.6 L7.6,7 Z" />
								</Button>
