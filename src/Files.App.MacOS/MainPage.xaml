						Grid.Column="2"
						Background="{ThemeResource FilesCardBrush}"
						BorderBrush="{ThemeResource FilesCardBorderBrush}"
						BorderThickness="1"
						CornerRadius="8"
						PointerPressed="PaneBorder_PointerPressed"
						Tag="Secondary"
						Visibility="{Binding ActiveTab.IsSplitView, Converter={StaticResource BooleanToVisibilityConverter}}">
						<Border.ContextFlyout>
							<MenuFlyout x:Name="SecondaryBackgroundContextFlyout" Opening="SecondaryBackgroundContextFlyout_Opening">
								<MenuFlyoutSubItem Tag="New">
									<MenuFlyoutItem x:Uid="NewFolderMenuItem" Click="NewButton_Click" Tag="NewFolder" />
									<MenuFlyoutItem x:Uid="NewTextFileMenuItem" Click="NewTextFileButton_Click" Tag="NewTextFile" />
								</MenuFlyoutSubItem>
								<MenuFlyoutItem x:Uid="BackgroundPasteItem" Click="PasteButton_Click" Tag="Paste" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem x:Uid="BackgroundTerminalItem" Click="TerminalButton_Click" Tag="Terminal" />
								<MenuFlyoutItem x:Uid="BackgroundRefreshItem" Click="RefreshButton_Click" Tag="Refresh" />
								<MenuFlyoutSeparator />
								<MenuFlyoutSubItem Tag="Sort">
									<ToggleMenuFlyoutItem x:Uid="SortNameItem" Click="SortFieldMenuItem_Click" Tag="Name" />
									<ToggleMenuFlyoutItem x:Uid="SortModifiedItem" Click="SortFieldMenuItem_Click" Tag="Modified" />
									<ToggleMenuFlyoutItem x:Uid="SortSizeItem" Click="SortFieldMenuItem_Click" Tag="Size" />
									<MenuFlyoutSeparator />
									<ToggleMenuFlyoutItem x:Uid="SortAscendingItem" Click="SortDirectionMenuItem_Click" Tag="Ascending" />
									<ToggleMenuFlyoutItem x:Uid="SortDescendingItem" Click="SortDirectionMenuItem_Click" Tag="Descending" />
								</MenuFlyoutSubItem>
								<MenuFlyoutSubItem Tag="View">
									<ToggleMenuFlyoutItem x:Uid="BackgroundGridViewItem" Click="GridViewStatusButton_Click" Tag="Grid" />
									<ToggleMenuFlyoutItem x:Uid="BackgroundDetailsViewItem" Click="DetailsViewStatusButton_Click" Tag="Details" />
								</MenuFlyoutSubItem>
							</MenuFlyout>
						</Border.ContextFlyout>
						<Grid>
							<ItemsView
								x:Name="SecondaryGridItems"
								AllowDrop="True"
								DragOver="Items_DragOver"
								Drop="Items_Drop"
								ItemsSource="{Binding ActiveTab.SecondaryBrowser.Items}"
								IsItemInvokedEnabled="True"
								ItemInvoked="GridItems_ItemInvoked"
								KeyDown="Items_KeyDown"
								SelectionChanged="GridItems_SelectionChanged"
								SelectionMode="Extended"
								Visibility="{Binding ActiveTab.SecondaryBrowser.IsGridView, Converter={StaticResource BooleanToVisibilityConverter}}">
								<ItemsView.Layout>
									<UniformGridLayout
										ItemsJustification="Start"
										MinColumnSpacing="4"
										MinItemHeight="108"
										MinItemWidth="116"
										MinRowSpacing="4"
										Orientation="Horizontal" />
								</ItemsView.Layout>
								<ItemsView.ItemTemplate>
									<DataTemplate>
										<ItemContainer Width="116" Height="108" AutomationProperties.Name="{Binding AccessibilityName}" RightTapped="Item_RightTapped">
										<Grid CanDrag="True" Background="Transparent" DragStarting="GridItem_DragStarting" RowDefinitions="72,*" ToolTipService.ToolTip="{Binding Path}">
											<Grid Width="64" Height="64" HorizontalAlignment="Center">
											<PathIcon Width="44" Height="44" Data="{Binding Converter={StaticResource FileSystemItemToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.72" Visibility="{Binding HasThumbnail, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
												<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
											</Grid>
											<TextBlock Grid.Row="1" HorizontalAlignment="Center" MaxLines="2" Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
										</Grid>
										</ItemContainer>
									</DataTemplate>
								</ItemsView.ItemTemplate>
							</ItemsView>

							<Grid
								Visibility="{Binding ActiveTab.SecondaryBrowser.IsGridView, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
								RowDefinitions="36,*">
								<Border
									Grid.Row="0"
									Background="{ThemeResource FilesSubtleBrush}"
									BorderBrush="{ThemeResource FilesCardBorderBrush}"
									BorderThickness="0,0,0,1">
									<Grid Padding="8,0" ColumnDefinitions="28,*,140,90">
										<Button x:Name="SecondaryNameHeaderButton" Grid.Column="1" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Name">
											<StackPanel Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="NameColumn" /><PathIcon x:Name="SecondaryNameSortIndicator" Width="10" Height="10" Visibility="Collapsed" /></StackPanel>
										</Button>
										<Button x:Name="SecondaryModifiedHeaderButton" Grid.Column="2" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Modified">
											<StackPanel Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="ModifiedColumn" /><PathIcon x:Name="SecondaryModifiedSortIndicator" Width="10" Height="10" Visibility="Collapsed" /></StackPanel>
										</Button>
										<Button x:Name="SecondarySizeHeaderButton" Grid.Column="3" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Size">
											<StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="SizeColumn" /><PathIcon x:Name="SecondarySizeSortIndicator" Width="10" Height="10" Visibility="Collapsed" /></StackPanel>
										</Button>
									</Grid>
								</Border>
								<ListView
									x:Name="SecondaryDetailsItems"
									AllowDrop="True"
									CanDragItems="True"
									DragItemsStarting="Items_DragItemsStarting"
									DragOver="Items_DragOver"
									Drop="Items_Drop"
									Grid.Row="1"
									ItemsSource="{Binding ActiveTab.SecondaryBrowser.Items}"
									DoubleTapped="Items_DoubleTapped"
									KeyDown="Items_KeyDown"
									SelectionChanged="Items_SelectionChanged"
									SelectionMode="Extended">
									<ListView.ItemsPanel>
										<ItemsPanelTemplate>
											<ItemsStackPanel Orientation="Vertical" />
										</ItemsPanelTemplate>
									</ListView.ItemsPanel>
									<ListView.ItemTemplate>
										<DataTemplate>
											<Grid MinHeight="36" Padding="8,4" AutomationProperties.Name="{Binding AccessibilityName}" Background="Transparent" ColumnDefinitions="28,*,140,90" RightTapped="Item_RightTapped" ToolTipService.ToolTip="{Binding Path}">
												<Grid Grid.Column="0" Width="24" Height="24">
												<PathIcon Width="20" Height="20" Data="{Binding Converter={StaticResource FileSystemItemToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.72" Visibility="{Binding HasThumbnail, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
													<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
												</Grid>
												<StackPanel Grid.Column="1" VerticalAlignment="Center">
													<TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
													<TextBlock
														FontSize="11"
														Foreground="{ThemeResource TextFillColorSecondaryBrush}"
														Text="{Binding SearchLocation}"
														TextTrimming="CharacterEllipsis"
														Visibility="{Binding IsSearchResult, Converter={StaticResource BooleanToVisibilityConverter}}" />
												</StackPanel>
												<TextBlock Grid.Column="2" Text="{Binding ModifiedText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
												<TextBlock Grid.Column="3" Text="{Binding SizeText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
											</Grid>
										</DataTemplate>
									</ListView.ItemTemplate>
								</ListView>
							</Grid>

							<StackPanel
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="8"
								Visibility="{Binding ActiveTab.SecondaryBrowser.IsEmptyFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
								<PathIcon x:Name="SecondaryEmptyFolderIcon" Width="64" Height="64" Data="M2,12 H25 L31,18 H62 V54 H2 Z M7,22 V49 H57 V22 Z" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.32" />
								<TextBlock x:Uid="EmptyFolderHeading" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
								<TextBlock x:Uid="EmptyFolderDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" />
							</StackPanel>
							<StackPanel
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="8"
								Visibility="{Binding ActiveTab.SecondaryBrowser.HasNoSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
								<PathIcon x:Name="SecondaryNoResultsIcon" Width="56" Height="56" Data="M24,4 A20,20 0 1 0 24,44 A20,20 0 0 0 24,4 Z M24,10 A14,14 0 1 1 24,38 A14,14 0 0 1 24,10 Z M38,39 L44,34 L56,47 L51,52 Z M18,18 H30 V22 H18 Z M18,27 H27 V31 H18 Z" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.32" />
								<TextBlock x:Uid="NoSearchResultsHeading" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
								<TextBlock x:Uid="NoSearchResultsDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" />
							</StackPanel>

							<ProgressRing
								Width="28"
								Height="28"
								HorizontalAlignment="Center"
								IsActive="{Binding ActiveTab.SecondaryBrowser.IsLoading}"
								VerticalAlignment="Center" />
						</Grid>
					</Border>
				</Grid>

				<Border
					x:Name="PreviewPaneBorder"
					Grid.Row="1"
					Width="312"
					Margin="8,0,0,0"
					HorizontalAlignment="Right"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="1"
					CornerRadius="8"
					Visibility="Collapsed">
					<Grid Padding="16" RowDefinitions="Auto,*,Auto">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock x:Uid="PreviewPaneHeading" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
							<Button
								x:Name="ClosePreviewPaneButton"
								Grid.Column="1"
								Click="ClosePreviewPaneButton_Click"
								Style="{StaticResource NavigationButtonStyle}">
								<PathIcon Width="11" Height="11" Data="M3,2 L10,9 L17,2 L18,3 L11,10 L18,17 L17,18 L10,11 L3,18 L2,17 L9,10 L2,3 Z" />
							</Button>
						</Grid>
						<ScrollViewer Grid.Row="1" Margin="0,16,0,8" VerticalScrollBarVisibility="Auto">
							<Grid>
								<TextBlock
									x:Name="PreviewSelectionSummary"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									TextAlignment="Center"
									TextWrapping="Wrap" />
								<StackPanel x:Name="PreviewPaneContent" Spacing="10" Visibility="Collapsed">
									<Grid Width="160" Height="160" HorizontalAlignment="Center">
										<PathIcon Width="88" Height="88" Data="{Binding Converter={StaticResource FileSystemItemToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" Opacity="0.58" Visibility="{Binding HasThumbnail, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
										<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
									</Grid>
									<TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
									<TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Path}" TextAlignment="Center" TextWrapping="Wrap" />
									<Border Height="1" Margin="0,4" Background="{ThemeResource FilesCardBorderBrush}" />
									<Grid ColumnDefinitions="110,*">
										<TextBlock x:Uid="PreviewModifiedLabel" />
										<TextBlock Grid.Column="1" Text="{Binding ModifiedText}" TextWrapping="Wrap" />
									</Grid>
									<Grid ColumnDefinitions="110,*">
										<TextBlock x:Uid="PreviewSizeLabel" />
										<TextBlock Grid.Column="1" Text="{Binding SizeText}" />
									</Grid>
								</StackPanel>
							</Grid>
						</ScrollViewer>
						<Button
							x:Name="PreviewPaneQuickLookButton"
							x:Uid="PreviewPaneQuickLookButton"
							Grid.Row="2"
							Click="PreviewPaneQuickLookButton_Click"
							HorizontalAlignment="Stretch"
							IsEnabled="False" />
					</Grid>
				</Border>

				<!--  Status bar  -->
				<Grid Grid.Row="2" Margin="12,0" ColumnDefinitions="*,180,Auto,Auto" ColumnSpacing="8">
					<TextBlock
						x:Name="StatusTextBlock"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="{Binding ActiveBrowser.StatusText}"
					TextTrimming="CharacterEllipsis"
					VerticalAlignment="Center" />
					<ProgressBar
						x:Name="FileOperationProgressBar"
						Grid.Column="1"
						Maximum="100"
						Visibility="Collapsed"
						VerticalAlignment="Center"
						Value="0" />
					<Button
						x:Name="CancelOperationButton"
						x:Uid="CancelOperationButton"
						Grid.Column="2"
						Click="CancelOperationButton_Click"
						Style="{StaticResource ToolbarButtonStyle}"
						Visibility="Collapsed" />
					<Border Grid.Column="3" Padding="2" VerticalAlignment="Center" Background="{ThemeResource FilesSubtleBrush}" CornerRadius="5">
						<StackPanel Orientation="Horizontal" Spacing="1">
							<Button x:Name="GridViewStatusButton" Click="GridViewStatusButton_Click" Style="{StaticResource StatusViewButtonStyle}">
								<PathIcon Width="16" Height="16" Data="M1,1 H7 V7 H1 Z M2,2 V6 H6 V2 Z M9,1 H15 V7 H9 Z M10,2 V6 H14 V2 Z M1,9 H7 V15 H1 Z M2,10 V14 H6 V10 Z M9,9 H15 V15 H9 Z M10,10 V14 H14 V10 Z" />
							</Button>
							<Button x:Name="DetailsViewStatusButton" Click="DetailsViewStatusButton_Click" Style="{StaticResource StatusViewButtonStyle}">
								<PathIcon Width="16" Height="16" Data="M3,2 A1,1 0 1 0 3,4 A1,1 0 0 0 3,2 Z M6,2 H15 V4 H6 Z M3,7 A1,1 0 1 0 3,9 A1,1 0 0 0 3,7 Z M6,7 H15 V9 H6 Z M3,12 A1,1 0 1 0 3,14 A1,1 0 0 0 3,12 Z M6,12 H15 V14 H6 Z" />
							</Button>
						</StackPanel>
					</Border>
				</Grid>
			</Grid>
		</Grid>
	</Grid>

</Page>
