<Page
	x:Class="Files.App.MacOS.MainPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="using:Files.App.MacOS.Converters"
	xmlns:viewmodels="using:Files.App.MacOS.ViewModels"
	Background="{ThemeResource FilesBackgroundBrush}">

	<Page.Resources>
		<converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
	</Page.Resources>
	<Page.KeyboardAccelerators>
		<KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Control" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Control" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F" Modifiers="Control" Invoked="SearchAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Control" Invoked="AddressAccelerator_Invoked" />
		<KeyboardAccelerator Key="A" Modifiers="Control" Invoked="SelectAllAccelerator_Invoked" />
		<KeyboardAccelerator Key="I" Modifiers="Control,Shift" Invoked="InvertSelectionAccelerator_Invoked" />
		<KeyboardAccelerator Key="C" Modifiers="Control,Shift" Invoked="CopyPathAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Control,Shift" Invoked="RedoAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Control,Shift" Invoked="SplitViewAccelerator_Invoked" />
		<KeyboardAccelerator Key="Delete" Modifiers="Shift" Invoked="PermanentDeleteAccelerator_Invoked" />
		<KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OpenInNewTabAccelerator_Invoked" />
		<!--  Uno maps the macOS Command key to the WinUI Windows modifier.  -->
		<KeyboardAccelerator Key="C" Modifiers="Windows" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Windows" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Windows" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F" Modifiers="Windows" Invoked="SearchAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Windows" Invoked="AddressAccelerator_Invoked" />
		<KeyboardAccelerator Key="A" Modifiers="Windows" Invoked="SelectAllAccelerator_Invoked" />
		<KeyboardAccelerator Key="I" Modifiers="Windows,Shift" Invoked="InvertSelectionAccelerator_Invoked" />
		<KeyboardAccelerator Key="C" Modifiers="Windows,Shift" Invoked="CopyPathAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows" Invoked="UndoAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows,Shift" Invoked="RedoAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows,Shift" Invoked="SplitViewAccelerator_Invoked" />
		<KeyboardAccelerator Key="Enter" Modifiers="Windows" Invoked="OpenInNewTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows" Invoked="DuplicateAccelerator_Invoked" />
	</Page.KeyboardAccelerators>

	<Grid RowDefinitions="44,48,*">
		<!--  Tab strip  -->
		<TabView
			x:Name="Tabs"
			Grid.Row="0"
			Margin="4,4,4,0"
			AddTabButtonClick="Tabs_AddTabButtonClick"
			IsAddTabButtonVisible="False"
			SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
			SelectionChanged="Tabs_SelectionChanged"
			TabCloseRequested="Tabs_TabCloseRequested"
			TabItemsSource="{Binding Tabs}">
			<TabView.TabItemTemplate>
				<DataTemplate x:DataType="viewmodels:BrowserTabViewModel">
					<TabViewItem IsClosable="False">
						<TabViewItem.Header>
							<StackPanel Orientation="Horizontal" Spacing="7">
								<TextBlock FontSize="14" Text="📁" VerticalAlignment="Center" />
								<TextBlock MaxWidth="180" Text="{x:Bind Header, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
								<Button Width="22" Height="22" Padding="0" Click="TabHeaderCloseButton_Click" Content="×" Style="{StaticResource NavigationButtonStyle}" Tag="{Binding}" />
							</StackPanel>
						</TabViewItem.Header>
					</TabViewItem>
				</DataTemplate>
			</TabView.TabItemTemplate>
			<TabView.TabStripFooter>
				<Button x:Name="NewTabButton" Width="32" Click="NewTabButton_Click" Content="＋" Style="{StaticResource NavigationButtonStyle}" />
			</TabView.TabStripFooter>
		</TabView>

		<!--  Address toolbar  -->
		<Grid
			Grid.Row="1"
			Padding="8,6"
			Background="{ThemeResource FilesToolbarBrush}"
			ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
			ColumnSpacing="4">
			<Button
				x:Name="ToggleSidebarButton"
				x:Uid="ToggleSidebarButton"
				Grid.Column="0"
				Click="ToggleSidebarButton_Click"
				Style="{StaticResource NavigationButtonStyle}" />
			<Button
				x:Uid="BackButton"
				Grid.Column="1"
				Click="BackButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoBack}"
				Style="{StaticResource NavigationButtonStyle}" />
			<Button
				x:Uid="ForwardButton"
				Grid.Column="2"
				Click="ForwardButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoForward}"
				Style="{StaticResource NavigationButtonStyle}" />
			<Button
				x:Uid="UpButton"
				Grid.Column="3"
				Click="UpButton_Click"
				Style="{StaticResource NavigationButtonStyle}" />
			<Button
				x:Uid="RefreshButton"
				Grid.Column="4"
				Click="RefreshButton_Click"
				Style="{StaticResource NavigationButtonStyle}" />

			<Border
				x:Name="AddressBarBorder"
				Grid.Column="5"
				Margin="4,0"
				Background="{ThemeResource FilesCardBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="1"
				CornerRadius="6"
				PointerPressed="AddressBarBorder_PointerPressed">
				<Grid>
					<ScrollViewer
						x:Name="BreadcrumbScrollViewer"
						HorizontalScrollBarVisibility="Hidden"
						HorizontalScrollMode="Enabled"
						VerticalScrollMode="Disabled">
						<StackPanel
							x:Name="BreadcrumbPanel"
							Margin="4,0"
							Orientation="Horizontal" />
					</ScrollViewer>
					<TextBox
						x:Name="AddressBox"
						x:Uid="AddressBox"
						Background="Transparent"
						BorderThickness="0"
						KeyDown="AddressBox_KeyDown"
						LostFocus="AddressBox_LostFocus"
						Visibility="Collapsed" />
				</Grid>
			</Border>

			<Grid Grid.Column="6" Width="260">
				<TextBox
					x:Name="SearchBox"
					x:Uid="SearchBox"
					Padding="12,0,36,0"
					Text="{Binding ActiveBrowser.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
					TextChanged="SearchBox_TextChanged" />
				<Button
					x:Name="SearchOptionsButton"
					Width="32"
					HorizontalAlignment="Right"
					Background="Transparent"
					BorderThickness="0"
					Click="SearchOptionsButton_Click"
					Content="⌄" />
			</Grid>
		</Grid>

		<!--  Sidebar and file area  -->
		<Grid x:Name="WorkspaceGrid" Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="SidebarColumn" Width="228" />
				<ColumnDefinition x:Name="SidebarDividerColumn" Width="6" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Border
				x:Name="SidebarBorder"
				Grid.Column="0"
				Background="{ThemeResource FilesSidebarBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="0,1,1,0">
				<Grid Padding="8" RowDefinitions="*,Auto">
					<ListView
						x:Name="SidebarList"
						HorizontalContentAlignment="Stretch"
						ItemContainerStyle="{StaticResource SidebarListItemStyle}"
						ItemsSource="{Binding Locations}"
						SelectionChanged="SidebarList_SelectionChanged"
						SelectionMode="Single">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid>
								<Grid
									MinHeight="32"
									Padding="8,6,8,2"
									ColumnDefinitions="16,*"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
									<TextBlock FontSize="11" Text="{Binding DisplayGlyph}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Name}" VerticalAlignment="Center" />
								</Grid>
								<Grid
									MinHeight="36"
									Padding="8,0"
									ColumnDefinitions="24,*"
									ColumnSpacing="8"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
									<TextBlock Text="{Binding DisplayGlyph}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
								</Grid>
							</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>

					<StackPanel Grid.Row="1" Spacing="2">
						<Border Height="1" Margin="4,2" Background="{ThemeResource FilesCardBorderBrush}" />
						<Button
							x:Name="OpenFolderButton"
							x:Uid="OpenFolderButton"
							Click="OpenFolderButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}" />
						<Button
							x:Name="ConnectServerButton"
							x:Uid="ConnectServerButton"
							Click="ConnectServerButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}" />
						<Button
							x:Name="ClearRecentButton"
							x:Uid="ClearRecentButton"
							Click="ClearRecentButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}"
							Visibility="{Binding HasRecentLocations, Converter={StaticResource BooleanToVisibilityConverter}}" />
						<Button
							x:Name="SettingsButton"
							x:Uid="SettingsButton"
							Click="SettingsButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}" />
					</StackPanel>
				</Grid>
			</Border>
			<Border
				x:Name="SidebarDivider"
				Grid.Column="1"
				Background="Transparent"
				PointerCaptureLost="SidebarDivider_PointerCaptureLost"
				PointerMoved="SidebarDivider_PointerMoved"
				PointerPressed="SidebarDivider_PointerPressed"
				PointerReleased="SidebarDivider_PointerReleased">
				<Border Width="1" HorizontalAlignment="Center" Background="{ThemeResource FilesCardBorderBrush}" />
			</Border>

			<Grid Grid.Column="2" Padding="8,6,8,8" RowDefinitions="48,*,36">
				<!--  File command toolbar  -->
				<Border
					x:Name="CommandToolbarBorder"
					Grid.Row="0"
					Margin="0,0,0,6"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="1"
					CornerRadius="8"
					SizeChanged="CommandToolbarBorder_SizeChanged">
					<Grid Padding="8,4" ColumnDefinitions="*,Auto">
						<ScrollViewer HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Enabled">
							<StackPanel Orientation="Horizontal" Spacing="2">
								<Button x:Name="UndoButton" x:Uid="UndoButton" Click="UndoButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="RedoButton" x:Uid="RedoButton" Click="RedoButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Border x:Name="HistoryCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Uid="NewButton" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout>
											<MenuFlyoutItem x:Uid="NewFolderMenuItem" Click="NewButton_Click" />
											<MenuFlyoutItem x:Uid="NewTextFileMenuItem" Click="NewTextFileButton_Click" />
										</MenuFlyout>
									</Button.Flyout>
								</Button>
								<Button x:Name="CutButton" x:Uid="CutButton" Click="CutButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="CopyButton" x:Uid="CopyButton" Click="CopyButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="PasteButton" x:Uid="PasteButton" Click="PasteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Border x:Name="EditCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Name="RenameButton" x:Uid="RenameButton" Click="RenameButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="ShareButton" x:Uid="ShareButton" Click="ShareButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="DeleteButton" x:Uid="DeleteButton" Click="DeleteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Border x:Name="SecondaryCommandSeparator" Width="1" Height="20" Margin="4,0" Background="{ThemeResource FilesCardBorderBrush}" />
								<Button x:Name="RevealButton" x:Uid="RevealButton" Click="RevealButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="PropertiesButton" x:Uid="PropertiesButton" Click="PropertiesButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="SelectionButton" x:Uid="SelectionButton" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout>
											<MenuFlyoutItem x:Uid="SelectAllMenuItem" Click="SelectAllMenuItem_Click" />
											<MenuFlyoutItem x:Uid="InvertSelectionMenuItem" Click="InvertSelectionMenuItem_Click" />
											<MenuFlyoutSeparator />
											<MenuFlyoutItem x:Name="CopyPathMenuItem" x:Uid="CopyPathMenuItem" Click="CopyPathMenuItem_Click" IsEnabled="False" />
										</MenuFlyout>
									</Button.Flyout>
								</Button>
								<Button x:Name="ArchiveButton" x:Uid="ArchiveButton" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}">
									<Button.Flyout>
										<MenuFlyout Opening="ArchiveFlyout_Opening">
											<MenuFlyoutItem x:Uid="CompressArchiveMenuItem" Click="CompressArchiveMenuItem_Click" />
											<MenuFlyoutItem x:Name="ExtractArchiveMenuItem" x:Uid="ExtractArchiveMenuItem" Click="ExtractArchiveMenuItem_Click" />
										</MenuFlyout>
									</Button.Flyout>
								</Button>
								<Button x:Name="FavoriteButton" x:Uid="FavoriteButton" Click="FavoriteButton_Click" IsEnabled="False" Style="{StaticResource ToolbarButtonStyle}" />
								<Button x:Name="TerminalButton" x:Uid="TerminalButton" Click="TerminalButton_Click" Style="{StaticResource ToolbarButtonStyle}" />
							</StackPanel>
						</ScrollViewer>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
							<Button x:Name="MoreCommandsButton" x:Uid="MoreCommandsButton" Style="{StaticResource ToolbarButtonStyle}" Visibility="Collapsed">
								<Button.Flyout>
									<MenuFlyout Opening="MoreCommandsFlyout_Opening">
										<MenuFlyoutItem x:Name="MoreRenameItem" x:Uid="ContextRenameItem" Click="ContextAction_Click" Tag="Rename" Visibility="Collapsed" />
										<MenuFlyoutItem x:Name="MoreShareItem" x:Uid="ContextShareItem" Click="ContextAction_Click" Tag="Share" Visibility="Collapsed" />
										<MenuFlyoutItem x:Name="MoreDeleteItem" x:Uid="ContextDeleteItem" Click="ContextAction_Click" Tag="Delete" Visibility="Collapsed" />
										<MenuFlyoutItem x:Name="MorePermanentDeleteItem" x:Uid="ContextPermanentDeleteItem" Click="ContextAction_Click" Tag="PermanentDelete" />
										<MenuFlyoutSeparator x:Name="MoreCompactSeparator" Visibility="Collapsed" />
										<MenuFlyoutItem x:Name="MoreRevealItem" x:Uid="ContextRevealItem" Click="ContextAction_Click" Tag="Reveal" />
										<MenuFlyoutItem x:Name="MorePropertiesItem" x:Uid="ContextPropertiesItem" Click="ContextAction_Click" Tag="Properties" />
									<MenuFlyoutSubItem x:Name="MoreSelectionSubItem">
											<MenuFlyoutItem x:Uid="SelectAllMenuItem" Click="SelectAllMenuItem_Click" />
											<MenuFlyoutItem x:Uid="InvertSelectionMenuItem" Click="InvertSelectionMenuItem_Click" />
											<MenuFlyoutItem x:Name="MoreCopyPathItem" x:Uid="CopyPathMenuItem" Click="CopyPathMenuItem_Click" />
										</MenuFlyoutSubItem>
									<MenuFlyoutSubItem x:Name="MoreArchiveSubItem">
											<MenuFlyoutItem x:Uid="CompressArchiveMenuItem" Click="CompressArchiveMenuItem_Click" />
											<MenuFlyoutItem x:Name="MoreExtractArchiveItem" x:Uid="ExtractArchiveMenuItem" Click="ExtractArchiveMenuItem_Click" />
										</MenuFlyoutSubItem>
										<MenuFlyoutItem x:Name="MoreFavoriteItem" x:Uid="ContextFavoriteItem" Click="ContextAction_Click" Tag="Favorite" />
										<MenuFlyoutItem x:Name="MoreTerminalItem" x:Uid="ContextTerminalItem" Click="ContextAction_Click" Tag="Terminal" />
									</MenuFlyout>
								</Button.Flyout>
							</Button>
							<Button x:Name="PreviewPaneButton" x:Uid="PreviewPaneButton" Click="PreviewPaneButton_Click" Style="{StaticResource ToolbarButtonStyle}" />
							<Button x:Name="SplitViewButton" x:Uid="SplitViewButton" Click="SplitViewButton_Click" Style="{StaticResource ToolbarButtonStyle}" />
							<Button x:Uid="SortButton" Style="{StaticResource ToolbarButtonStyle}">
								<Button.Flyout>
									<MenuFlyout Opening="SortFlyout_Opening">
										<ToggleMenuFlyoutItem x:Name="SortNameItem" x:Uid="SortNameItem" Click="SortFieldMenuItem_Click" IsChecked="True" Tag="Name" />
										<ToggleMenuFlyoutItem x:Name="SortModifiedItem" x:Uid="SortModifiedItem" Click="SortFieldMenuItem_Click" Tag="Modified" />
										<ToggleMenuFlyoutItem x:Name="SortSizeItem" x:Uid="SortSizeItem" Click="SortFieldMenuItem_Click" Tag="Size" />
										<MenuFlyoutSeparator />
										<ToggleMenuFlyoutItem x:Name="SortAscendingItem" x:Uid="SortAscendingItem" Click="SortDirectionMenuItem_Click" IsChecked="True" Tag="Ascending" />
										<ToggleMenuFlyoutItem x:Name="SortDescendingItem" x:Uid="SortDescendingItem" Click="SortDirectionMenuItem_Click" Tag="Descending" />
									</MenuFlyout>
								</Button.Flyout>
							</Button>
							<Button
								x:Uid="ViewButton"
								Click="ViewButton_Click"
								Style="{StaticResource ToolbarButtonStyle}" />
						</StackPanel>
					</Grid>
				</Border>

				<!--  Grid layout  -->
				<Grid
					x:Name="PaneGrid"
					Grid.Row="1"
					SizeChanged="PaneGrid_SizeChanged">
					<Grid.ColumnDefinitions>
						<ColumnDefinition x:Name="PrimaryPaneColumn" Width="*" />
						<ColumnDefinition x:Name="SplitDividerColumn" Width="0" />
						<ColumnDefinition x:Name="SecondaryPaneColumn" Width="0" />
					</Grid.ColumnDefinitions>
				<Border
					x:Name="PrimaryPaneBorder"
					Grid.Column="0"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="2"
					CornerRadius="8"
					PointerPressed="PaneBorder_PointerPressed"
					Tag="Primary">
					<Grid>
						<ItemsView
							x:Name="GridItems"
							AllowDrop="True"
							DragOver="Items_DragOver"
							Drop="Items_Drop"
							ItemsSource="{Binding ActiveTab.Browser.Items}"
							IsItemInvokedEnabled="True"
							ItemInvoked="GridItems_ItemInvoked"
							KeyDown="Items_KeyDown"
							SelectionChanged="GridItems_SelectionChanged"
							SelectionMode="Extended"
							Visibility="{Binding ActiveTab.Browser.IsGridView, Converter={StaticResource BooleanToVisibilityConverter}}">
							<ItemsView.Layout>
								<UniformGridLayout
									ItemsJustification="Start"
									MinColumnSpacing="4"
									MinItemHeight="108"
									MinItemWidth="116"
									MinRowSpacing="4"
									Orientation="Horizontal" />
							</ItemsView.Layout>
							<ItemsView.ItemTemplate>
								<DataTemplate>
									<ItemContainer Width="116" Height="108">
									<Grid CanDrag="True" DragStarting="GridItem_DragStarting" RowDefinitions="72,*" RightTapped="Item_RightTapped" ToolTipService.ToolTip="{Binding Path}">
										<Grid.ContextFlyout>
											<MenuFlyout Opening="ItemContextFlyout_Opening">
												<MenuFlyoutItem x:Uid="ContextOpenItem" Click="ContextAction_Click" Tag="Open" />
												<MenuFlyoutItem x:Uid="ContextOpenWithItem" Click="ContextAction_Click" Tag="OpenWith" />
												<MenuFlyoutItem x:Uid="ContextOpenInNewTabItem" Click="ContextAction_Click" Tag="OpenInNewTab" />
												<MenuFlyoutItem x:Uid="ContextPreviewItem" Click="ContextAction_Click" Tag="Preview" />
												<MenuFlyoutItem x:Uid="ContextRevealItem" Click="ContextAction_Click" Tag="Reveal" />
												<MenuFlyoutItem x:Uid="ContextTerminalItem" Click="ContextAction_Click" Tag="Terminal" />
												<MenuFlyoutSeparator />
												<MenuFlyoutItem x:Uid="ContextCutItem" Click="ContextAction_Click" Tag="Cut" />
											<MenuFlyoutItem x:Uid="ContextCopyItem" Click="ContextAction_Click" Tag="Copy" />
											<MenuFlyoutItem x:Uid="ContextDuplicateItem" Click="ContextAction_Click" Tag="Duplicate" />
											<MenuFlyoutItem x:Uid="ContextCopyPathItem" Click="ContextAction_Click" Tag="CopyPath" />
												<MenuFlyoutItem x:Uid="ContextRenameItem" Click="ContextAction_Click" Tag="Rename" />
												<MenuFlyoutItem x:Uid="ContextShareItem" Click="ContextAction_Click" Tag="Share" />
												<MenuFlyoutSeparator />
												<MenuFlyoutItem x:Uid="ContextDeleteItem" Click="ContextAction_Click" Tag="Delete" />
												<MenuFlyoutItem x:Uid="ContextPermanentDeleteItem" Click="ContextAction_Click" Tag="PermanentDelete" />
												<MenuFlyoutItem x:Uid="ContextPropertiesItem" Click="ContextAction_Click" Tag="Properties" />
												<MenuFlyoutSeparator />
												<MenuFlyoutItem x:Uid="ContextCompressItem" Click="ContextAction_Click" Tag="Compress" />
												<MenuFlyoutItem x:Uid="ContextExtractItem" Click="ContextAction_Click" Tag="Extract" />
												<MenuFlyoutItem x:Uid="ContextFavoriteItem" Click="ContextAction_Click" Tag="Favorite" />
											</MenuFlyout>
										</Grid.ContextFlyout>
										<Grid Width="64" Height="64" HorizontalAlignment="Center">
											<TextBlock FontSize="44" HorizontalAlignment="Center" Text="{Binding Glyph}" VerticalAlignment="Center" />
											<Image Source="{Binding Thumbnail}" Stretch="Uniform" />
										</Grid>
										<TextBlock
											Grid.Row="1"
											HorizontalAlignment="Center"
											MaxLines="2"
											Text="{Binding Name}"
											TextAlignment="Center"
											TextTrimming="CharacterEllipsis"
											TextWrapping="Wrap" />
									</Grid>
									</ItemContainer>
								</DataTemplate>
							</ItemsView.ItemTemplate>
						</ItemsView>

						<!--  Details layout  -->
						<Grid
							Visibility="{Binding ActiveTab.Browser.IsGridView, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
							RowDefinitions="36,*">
							<Border
								Grid.Row="0"
								Background="{ThemeResource FilesSubtleBrush}"
								BorderBrush="{ThemeResource FilesCardBorderBrush}"
								BorderThickness="0,0,0,1">
								<Grid Padding="8,0" ColumnDefinitions="28,*,180,100">
									<Button x:Name="PrimaryNameHeaderButton" Grid.Column="1" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Name">
										<StackPanel Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="NameColumn" /><TextBlock x:Name="PrimaryNameSortIndicator" /></StackPanel>
									</Button>
									<Button x:Name="PrimaryModifiedHeaderButton" Grid.Column="2" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Modified">
										<StackPanel Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="ModifiedColumn" /><TextBlock x:Name="PrimaryModifiedSortIndicator" /></StackPanel>
									</Button>
									<Button x:Name="PrimarySizeHeaderButton" Grid.Column="3" Click="DetailsHeaderButton_Click" Style="{StaticResource DetailsHeaderButtonStyle}" Tag="Size">
										<StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6"><TextBlock x:Uid="SizeColumn" /><TextBlock x:Name="PrimarySizeSortIndicator" /></StackPanel>
									</Button>
								</Grid>
							</Border>
							<ListView
								x:Name="DetailsItems"
								AllowDrop="True"
								CanDragItems="True"
								DragItemsStarting="Items_DragItemsStarting"
								DragOver="Items_DragOver"
								Drop="Items_Drop"
								Grid.Row="1"
								ItemsSource="{Binding ActiveTab.Browser.Items}"
								DoubleTapped="Items_DoubleTapped"
								KeyDown="Items_KeyDown"
								SelectionChanged="Items_SelectionChanged"
								SelectionMode="Extended">
								<ListView.ItemsPanel>
									<ItemsPanelTemplate>
										<ItemsStackPanel Orientation="Vertical" />
