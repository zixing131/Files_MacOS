<Page
	x:Class="Files.App.MacOS.MainPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="using:Files.App.MacOS.Converters"
	xmlns:controls="using:Files.App.MacOS.Controls"
	xmlns:viewmodels="using:Files.App.MacOS.ViewModels"
	Background="{ThemeResource FilesBackgroundBrush}">

	<Page.Resources>
		<converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<converters:FileSystemItemToIconConverter x:Key="FileSystemItemToIconConverter" />
		<converters:SidebarGlyphToIconConverter x:Key="SidebarGlyphToIconConverter" />
		<MenuFlyout x:Key="ItemContextFlyout" Opening="ItemContextFlyout_Opening">
			<MenuFlyoutItem x:Uid="ContextOpenItem" Click="ContextAction_Click" Tag="Open" />
			<MenuFlyoutItem x:Uid="ContextOpenInNewTabItem" Click="ContextAction_Click" Tag="OpenInNewTab" />
			<MenuFlyoutItem x:Uid="ContextPreviewItem" Click="ContextAction_Click" Tag="Preview" />
			<MenuFlyoutSeparator />
			<MenuFlyoutItem x:Uid="ContextCutItem" Click="ContextAction_Click" Tag="Cut" />
			<MenuFlyoutItem x:Uid="ContextCopyItem" Click="ContextAction_Click" Tag="Copy" />
			<MenuFlyoutItem x:Uid="ContextRenameItem" Click="ContextAction_Click" Tag="Rename" />
			<MenuFlyoutItem x:Uid="ContextDeleteItem" Click="ContextAction_Click" Tag="MoveToTrash" />
			<MenuFlyoutSeparator />
			<MenuFlyoutItem x:Uid="ContextPropertiesItem" Click="ContextAction_Click" Tag="Properties" />
			<MenuFlyoutSubItem Tag="MoreActions">
				<MenuFlyoutItem x:Uid="ContextOpenWithItem" Click="ContextAction_Click" Tag="OpenWith" />
				<MenuFlyoutItem x:Uid="ContextRevealItem" Click="ContextAction_Click" Tag="Reveal" />
				<MenuFlyoutItem x:Uid="ContextTerminalItem" Click="ContextAction_Click" Tag="Terminal" />
				<MenuFlyoutSeparator />
				<MenuFlyoutItem x:Uid="ContextDuplicateItem" Click="ContextAction_Click" Tag="Duplicate" />
				<MenuFlyoutItem x:Uid="ContextCreateSymbolicLinkItem" Click="ContextAction_Click" Tag="CreateSymbolicLink" />
				<MenuFlyoutItem x:Uid="ContextCopyPathItem" Click="ContextAction_Click" Tag="CopyPath" />
				<MenuFlyoutItem x:Uid="ContextShareItem" Click="ContextAction_Click" Tag="Share" />
				<MenuFlyoutSeparator />
				<MenuFlyoutItem x:Uid="ContextCompressItem" Click="ContextAction_Click" Tag="Compress" />
				<MenuFlyoutItem x:Uid="ContextExtractItem" Click="ContextAction_Click" Tag="Extract" />
				<MenuFlyoutItem x:Uid="ContextFavoriteItem" Click="ContextAction_Click" Tag="Favorite" />
				<MenuFlyoutItem x:Uid="ContextPermanentDeleteItem" Click="ContextAction_Click" Tag="PermanentDelete" />
			</MenuFlyoutSubItem>
		</MenuFlyout>
	</Page.Resources>
	<Page.KeyboardAccelerators>
		<KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Control" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Control" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="NextTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="PreviousTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number1" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number2" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number3" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number4" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number5" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number6" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number7" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number8" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Number9" Modifiers="Control" Invoked="SelectNumberedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="Delete" Modifiers="Shift" Invoked="PermanentDeleteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F6" Invoked="CycleFocusAccelerator_Invoked" />
		<KeyboardAccelerator Key="F6" Modifiers="Shift" Invoked="CycleFocusAccelerator_Invoked" />
		<!--  Uno maps the macOS Command key to the WinUI Windows modifier.  -->
		<KeyboardAccelerator Key="C" Modifiers="Windows" Invoked="CopyAccelerator_Invoked" />
		<KeyboardAccelerator Key="X" Modifiers="Windows" Invoked="CutAccelerator_Invoked" />
		<KeyboardAccelerator Key="V" Modifiers="Windows" Invoked="PasteAccelerator_Invoked" />
		<KeyboardAccelerator Key="F" Modifiers="Windows" Invoked="SearchAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Windows" Invoked="AddressAccelerator_Invoked" />
		<KeyboardAccelerator Key="A" Modifiers="Windows" Invoked="SelectAllAccelerator_Invoked" />
		<KeyboardAccelerator Key="I" Modifiers="Windows,Shift" Invoked="InvertSelectionAccelerator_Invoked" />
		<KeyboardAccelerator Key="C" Modifiers="Windows,Shift" Invoked="CopyPathAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows" Invoked="UndoAccelerator_Invoked" />
		<KeyboardAccelerator Key="Z" Modifiers="Windows,Shift" Invoked="RedoAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows,Shift" Invoked="SplitViewAccelerator_Invoked" />
		<KeyboardAccelerator Key="Enter" Modifiers="Windows" Invoked="OpenInNewTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="D" Modifiers="Windows" Invoked="DuplicateAccelerator_Invoked" />
		<KeyboardAccelerator Key="L" Modifiers="Windows,Menu" Invoked="CreateSymbolicLinkAccelerator_Invoked" />
		<KeyboardAccelerator Key="N" Modifiers="Windows" Invoked="NewWindowAccelerator_Invoked" />
		<KeyboardAccelerator Key="W" Modifiers="Windows,Shift" Invoked="CloseWindowAccelerator_Invoked" />
		<KeyboardAccelerator Key="T" Modifiers="Windows,Shift" Invoked="ReopenClosedTabAccelerator_Invoked" />
		<KeyboardAccelerator Key="K" Modifiers="Windows,Shift" Invoked="DuplicateTabAccelerator_Invoked" />
	</Page.KeyboardAccelerators>

	<Grid x:Name="RootLayout" IsHitTestVisible="False" Opacity="0" RowDefinitions="44,48,*">
		<!--  Tab strip  -->
		<Border x:Name="TitleBarBackground" Grid.Row="0" Background="{ThemeResource FilesBackgroundBrush}" />
		<TabView
			x:Name="Tabs"
			Grid.Row="0"
			Margin="76,4,4,0"
			AddTabButtonClick="Tabs_AddTabButtonClick"
			AllowDropTabs="True"
			CanDragTabs="True"
			CanReorderTabs="True"
			IsAddTabButtonVisible="False"
			SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
			SelectionChanged="Tabs_SelectionChanged"
			PointerWheelChanged="Tabs_PointerWheelChanged"
			TabCloseRequested="Tabs_TabCloseRequested"
			TabDragCompleted="Tabs_TabDragCompleted"
			TabDroppedOutside="Tabs_TabDroppedOutside"
			TabItemsSource="{Binding Tabs}"
			TabWidthMode="Equal">
			<TabView.TabItemTemplate>
				<DataTemplate x:DataType="viewmodels:BrowserTabViewModel">
					<TabViewItem
						AutomationProperties.Name="{Binding Header}"
						MinWidth="132"
						MaxWidth="260"
						CornerRadius="7,7,0,0"
						HorizontalContentAlignment="Stretch"
						IsClosable="False"
						PointerPressed="TabItem_PointerPressed"
						PointerEntered="TabItem_PointerEntered"
						PointerExited="TabItem_PointerExited"
						Tag="{Binding}">
						<TabViewItem.ContextFlyout>
							<MenuFlyout Opening="TabContextFlyout_Opening">
								<MenuFlyoutItem x:Uid="NewTabMenuItem" Click="NewTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘T" />
								<MenuFlyoutItem x:Uid="DuplicateTabMenuItem" Click="DuplicateTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘⇧K" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="MoveTabToNewWindowMenuItem" Click="MoveTabToNewWindowMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem x:Uid="CloseTabMenuItem" Click="CloseTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘W" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseTabsToLeftMenuItem" Click="CloseTabsToLeftMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseTabsToRightMenuItem" Click="CloseTabsToRightMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutItem x:Uid="CloseOtherTabsMenuItem" Click="CloseOtherTabsMenuItem_Click" Tag="{Binding}" />
								<MenuFlyoutSeparator />
								<MenuFlyoutItem x:Uid="ReopenClosedTabMenuItem" Click="ReopenClosedTabMenuItem_Click" KeyboardAcceleratorTextOverride="⌘⇧T" />
							</MenuFlyout>
						</TabViewItem.ContextFlyout>
						<TabViewItem.Header>
							<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7" HorizontalAlignment="Stretch">
								<PathIcon Width="16" Height="16" Data="M2.5 1C1.11929 1 0 2.11929 0 3.5V12.5C0 13.8807 1.11929 15 2.5 15H13.5C14.8807 15 16 13.8807 16 12.5V5.5C16 4.11929 14.8807 3 13.5 3H7.70711L6.21967 1.51256C5.89148 1.18437 5.44636 1 4.98223 1H2.5ZM1 3.5C1 2.67157 1.67157 2 2.5 2H4.98223C5.18115 2 5.37191 2.07902 5.51256 2.21967L6.79289 3.5L5.43934 4.85355C5.34557 4.94732 5.21839 5 5.08579 5H1V3.5ZM1 6H5.08579C5.48361 6 5.86514 5.84196 6.14645 5.56066L7.70711 4H13.5C14.3284 4 15 4.67157 15 5.5V12.5C15 13.3284 14.3284 14 13.5 14H2.5C1.67157 14 1 13.3284 1 12.5V6Z" />
								<TextBlock Grid.Column="1" MaxWidth="180" HorizontalAlignment="Left" Text="{x:Bind Header, Mode=OneWay}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
								<Grid Grid.Column="2" Width="24" Height="24" Margin="4,0,2,0" HorizontalAlignment="Right">
									<Button Width="24" Height="24" Padding="0" Click="TabHeaderCloseButton_Click" Loaded="TabHeaderCloseButton_Loaded" Style="{StaticResource FilesFlatButtonStyle}" Tag="{Binding}" Visibility="{Binding ShowCloseButton, Converter={StaticResource BooleanToVisibilityConverter}}">
										<Path Width="12" Height="12" Data="M2,2 L10,10 M10,2 L2,10" Stroke="{ThemeResource TextFillColorPrimaryBrush}" StrokeThickness="1.35" />
									</Button>
								</Grid>
							</Grid>
						</TabViewItem.Header>
					</TabViewItem>
				</DataTemplate>
			</TabView.TabItemTemplate>
			<TabView.TabStripFooter>
				<Button x:Name="NewTabButton" Width="36" Height="32" Margin="4,0,0,0" Click="NewTabButton_Click" Style="{StaticResource NavigationButtonStyle}">
					<PathIcon Width="16" Height="16" Data="M8.5 2C8.77614 2 9 2.22386 9 2.5V7H13.5C13.7761 7 14 7.22386 14 7.5C14 7.77614 13.7761 8 13.5 8H9V12.5C9 12.7761 8.77614 13 8.5 13C8.22386 13 8 12.7761 8 12.5V8H3.5C3.22386 8 3 7.77614 3 7.5C3 7.22386 3.22386 7 3.5 7H8V2.5C8 2.22386 8.22386 2 8.5 2Z" />
				</Button>
			</TabView.TabStripFooter>
		</TabView>

		<!--  Address toolbar  -->
		<Grid
			x:Name="AddressToolbarGrid"
			Grid.Row="1"
			Padding="8,6"
			Background="{ThemeResource FilesToolbarBrush}"
			ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
			ColumnSpacing="4">
			<Button
				x:Name="ToggleSidebarButton"
				Grid.Column="0"
				Click="ToggleSidebarButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="20" Height="20" Data="M2,3 H18 V17 H2 Z M4,5 V15 H8 V5 Z M10,6 H16 V8 H10 Z M10,10 H16 V12 H10 Z" />
			</Button>
			<Button
				x:Name="BackButton"
				Grid.Column="1"
				Click="BackButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoBack}"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="20" Height="20" Data="M8,2 L1,10 L8,18 L10,16 L6,12 H18 V8 H6 L10,4 Z" />
			</Button>
			<Button
				x:Name="ForwardButton"
				Grid.Column="2"
				Click="ForwardButton_Click"
				IsEnabled="{Binding ActiveBrowser.CanGoForward}"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="20" Height="20" Data="M12,2 L19,10 L12,18 L10,16 L14,12 H2 V8 H14 L10,4 Z" />
			</Button>
			<Button
				x:Name="UpButton"
				Grid.Column="3"
				Click="UpButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="20" Height="20" Data="M10,2 L18,10 L16,12 L12,8 V18 H8 V8 L4,12 L2,10 Z" />
			</Button>
			<Button
				x:Name="RefreshButton"
				Grid.Column="4"
				Click="RefreshButton_Click"
				Style="{StaticResource NavigationButtonStyle}">
				<PathIcon Width="20" Height="20" Data="m2,8c0-3.31,2.69-6,6-6,1.78,0,3.37.77,4.47,2h-1.97c-.28,0-.5.22-.5.5s.22.5.5.5h3c.28,0,.5-.22.5-.5V1.5c0-.28-.22-.5-.5-.5s-.5.22-.5.5v1.6c-1.27-1.3-3.04-2.1-5-2.1-3.87,0-7,3.13-7,7s3.13,7,7,7,7-3.13,7-7c0-.18,0-.36-.02-.54-.02-.28-.26-.48-.54-.46-.28.02-.48.26-.46.54.01.15.02.31.02.46,0,3.31-2.69,6-6,6s-6-2.69-6-6Z" />
			</Button>

			<Border
				x:Name="AddressBarBorder"
				Grid.Column="5"
				Margin="6,0,4,0"
				Background="{ThemeResource FilesCardBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="1"
				CornerRadius="6"
				PointerPressed="AddressBarBorder_PointerPressed">
				<Grid>
					<ScrollViewer
						x:Name="BreadcrumbScrollViewer"
						HorizontalScrollBarVisibility="Hidden"
						HorizontalScrollMode="Enabled"
						VerticalScrollMode="Disabled">
						<StackPanel
							x:Name="BreadcrumbPanel"
							Margin="8,0"
							Orientation="Horizontal" />
					</ScrollViewer>
					<TextBox
						x:Name="AddressBox"
						x:Uid="AddressBox"
						Background="Transparent"
						BorderThickness="0"
						KeyDown="AddressBox_KeyDown"
						LostFocus="AddressBox_LostFocus"
						Visibility="Collapsed" />
				</Grid>
			</Border>

			<Grid Grid.Column="6" Width="260" Height="34" VerticalAlignment="Center">
				<TextBox
					x:Name="SearchBox"
					x:Uid="SearchBox"
					Height="34"
					Padding="12,3,36,0"
					VerticalAlignment="Center"
					VerticalContentAlignment="Center"
					Text="{Binding ActiveBrowser.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
					TextChanged="SearchBox_TextChanged" />
				<Button
					x:Name="SearchOptionsButton"
					Width="34"
					Height="32"
					HorizontalAlignment="Right"
					VerticalAlignment="Center"
					Background="Transparent"
					BorderThickness="0"
					Click="SearchOptionsButton_Click"
					Style="{StaticResource FilesFlatButtonStyle}">
					<PathIcon Width="14" Height="14" Data="M1.5,4.5 L7,10 L12.5,4.5 L14,6 L7,13 L0,6 Z" />
				</Button>
			</Grid>
		</Grid>

		<!--  Sidebar and file area  -->
		<Grid x:Name="WorkspaceGrid" Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="SidebarColumn" Width="228" />
				<ColumnDefinition x:Name="SidebarDividerColumn" Width="6" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Border
				x:Name="SidebarBorder"
				Grid.Column="0"
				Background="{ThemeResource FilesSidebarBrush}"
				BorderBrush="{ThemeResource FilesCardBorderBrush}"
				BorderThickness="0,1,1,0">
				<Grid Padding="8" RowDefinitions="*,Auto">
					<ListView
						x:Name="SidebarList"
						HorizontalContentAlignment="Stretch"
						IsItemClickEnabled="True"
						ItemContainerStyle="{StaticResource SidebarListItemStyle}"
						ItemClick="SidebarList_ItemClick"
						ItemsSource="{Binding Locations}"
						KeyDown="SidebarList_KeyDown"
						SelectionChanged="SidebarList_SelectionChanged"
						SelectionMode="Single">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Grid AutomationProperties.Name="{Binding AutomationName}">
								<Grid
									MinHeight="32"
									Padding="10,6,8,2"
									ColumnDefinitions="18,*"
									ColumnSpacing="6"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
									<PathIcon Width="12" Height="12" Data="{Binding DisplayGlyph, Converter={StaticResource SidebarGlyphToIconConverter}}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Name}" VerticalAlignment="Center" />
								</Grid>
								<Grid
									MinHeight="36"
									Padding="8,0"
									ColumnDefinitions="24,*,28"
									ColumnSpacing="8"
									Visibility="{Binding IsHeader, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
									<PathIcon Width="18" Height="18" Data="{Binding DisplayGlyph, Converter={StaticResource SidebarGlyphToIconConverter}}" Foreground="{ThemeResource FilesAccentBrush}" VerticalAlignment="Center" />
									<TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
									<Button
										x:Uid="EjectVolumeButton"
										Grid.Column="2"
										Width="26"
										Height="26"
										Padding="0"
										Click="EjectVolumeButton_Click"
										Style="{StaticResource FilesFlatButtonStyle}"
										Tag="{Binding}"
										Visibility="{Binding CanEject, Converter={StaticResource BooleanToVisibilityConverter}}">
										<PathIcon Width="14" Height="14" Data="M2,10 L7,4 L12,10 Z M2,12 H12 V14 H2 Z" />
									</Button>
								</Grid>
							</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>

					<StackPanel Grid.Row="1" Spacing="2">
						<Border Height="1" Margin="4,2" Background="{ThemeResource FilesCardBorderBrush}" />
						<Button
							x:Name="OpenFolderButton"
							Click="OpenFolderButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="OpenFolderButton" IconData="M2.5 1C1.11929 1 0 2.11929 0 3.5V12.5C0 13.8807 1.11929 15 2.5 15H13.5C14.8807 15 16 13.8807 16 12.5V5.5C16 4.11929 14.8807 3 13.5 3H7.70711L6.21967 1.51256C5.89148 1.18437 5.44636 1 4.98223 1H2.5ZM1 3.5C1 2.67157 1.67157 2 2.5 2H4.98223C5.18115 2 5.37191 2.07902 5.51256 2.21967L6.79289 3.5L5.43934 4.85355C5.34557 4.94732 5.21839 5 5.08579 5H1V3.5ZM1 6H5.08579C5.48361 6 5.86514 5.84196 6.14645 5.56066L7.70711 4H13.5C14.3284 4 15 4.67157 15 5.5V12.5C15 13.3284 14.3284 14 13.5 14H2.5C1.67157 14 1 13.3284 1 12.5V6Z" />
						</Button>
						<Button
							x:Name="ConnectServerButton"
							Click="ConnectServerButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="ConnectServerButton" IconData="M3.88,4.59 C3.48,4.85 3.01,5 2.5,5 A2.5,2.5 0 1 1 4.59,3.88 L6.63,5.92 A2.5,2.5 0 0 1 9.38,5.92 L11.42,3.88 A2.5,2.5 0 1 1 12.12,4.59 L10.08,6.63 A2.5,2.5 0 0 1 10.08,9.38 L12.12,11.42 A2.5,2.5 0 1 1 11.42,12.12 L9.38,10.08 A2.5,2.5 0 0 1 6.63,10.08 L4.59,12.12 A2.5,2.5 0 1 1 3.88,11.42 L5.92,9.38 A2.5,2.5 0 0 1 5.92,6.63 Z M2.5,1 A1.5,1.5 0 1 0 2.5,4 A1.5,1.5 0 0 0 2.5,1 Z M13.5,1 A1.5,1.5 0 1 0 13.5,4 A1.5,1.5 0 0 0 13.5,1 Z M8,6.5 A1.5,1.5 0 1 0 8,9.5 A1.5,1.5 0 0 0 8,6.5 Z M2.5,12 A1.5,1.5 0 1 0 2.5,15 A1.5,1.5 0 0 0 2.5,12 Z M13.5,12 A1.5,1.5 0 1 0 13.5,15 A1.5,1.5 0 0 0 13.5,12 Z" />
						</Button>
						<Button
							x:Name="ClearRecentButton"
							Click="ClearRecentButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}"
							Visibility="{Binding HasRecentLocations, Converter={StaticResource BooleanToVisibilityConverter}}">
							<controls:CommandLabel x:Uid="ClearRecentButton" IconData="M10,2 A8,8 0 0 1 17,6 V2 H19 V9 H12 V7 H15 A6,6 0 1 0 16,13 L18,14 A8,8 0 1 1 10,2 Z M6,8 L8,6 L10,8 L12,6 L14,8 L12,10 L14,12 L12,14 L10,12 L8,14 L6,12 L8,10 Z" />
						</Button>
						<Button
							x:Name="SettingsButton"
							Click="SettingsButton_Click"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Style="{StaticResource ToolbarButtonStyle}">
							<controls:CommandLabel x:Uid="SettingsButton" IconData="M7,0 H9 L9.4,2.6 L11.3,3.2 L12.8,1.8 L14.2,3.2 L12.8,4.7 L13.4,6.6 L16,7 V9 L13.4,9.4 L12.8,11.3 L14.2,12.8 L12.8,14.2 L11.3,12.8 L9.4,13.4 L9,16 H7 L6.6,13.4 L4.7,12.8 L3.2,14.2 L1.8,12.8 L3.2,11.3 L2.6,9.4 L0,9 V7 L2.6,6.6 L3.2,4.7 L1.8,3.2 L3.2,1.8 L4.7,3.2 L6.6,2.6 Z M8,5 A3,3 0 1 0 8,11 A3,3 0 0 0 8,5 Z M8,7 A1,1 0 1 1 8,9 A1,1 0 0 1 8,7 Z" />
						</Button>
					</StackPanel>
				</Grid>
			</Border>
			<Button
				x:Name="SidebarDivider"
				Grid.Column="1"
				KeyDown="SidebarDivider_KeyDown"
				Style="{StaticResource DividerButtonStyle}">
				<Border x:Name="SidebarDividerLine" Width="1" HorizontalAlignment="Center" Background="{ThemeResource FilesCardBorderBrush}" />
			</Button>

			<Grid Grid.Column="2" Padding="8,6,8,8" RowDefinitions="48,*,36">
				<!--  File command toolbar  -->
				<Border
					x:Name="CommandToolbarBorder"
					Grid.Row="0"
					Margin="0,0,0,6"
					Background="{ThemeResource FilesCardBrush}"
					BorderBrush="{ThemeResource FilesCardBorderBrush}"
					BorderThickness="1"
					CornerRadius="8"
					SizeChanged="CommandToolbarBorder_SizeChanged">
					<Grid Padding="8,4" ColumnDefinitions="*,Auto">
